{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "scripts/pre-tool-check.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "scripts/post-tool-log.sh",
            "timeout": 3
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": ["Read:*", "Bash:git:*", "Bash:npm:*", "Bash:pnpm:*", "Bash:npx:*"],
    "deny": ["Bash:rm -rf:*", "Bash:sudo:*"]
  }
}
